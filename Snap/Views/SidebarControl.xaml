<UserControl x:Class="Snap.Views.SidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ClipToBounds="False">

    <Grid ClipToBounds="False">
        <!-- Icon Strip (always visible, 40px) -->
        <Border x:Name="IconStrip" Width="40" HorizontalAlignment="Left"
                Background="#A01A1A22" BorderBrush="#30AAAACC" BorderThickness="0,0,1,0"
                MouseEnter="Sidebar_MouseEnter"
                MouseLeave="IconStrip_MouseLeave">
            <StackPanel VerticalAlignment="Top" Margin="0,8,0,0">
                <!-- Pinned -->
                <Border Padding="0,6" Cursor="Hand" ToolTip="Pinned">
                    <TextBlock Text="&#xE718;" FontFamily="Segoe Fluent Icons"
                               FontSize="16" Foreground="#808090"
                               HorizontalAlignment="Center"/>
                </Border>
                <!-- Today -->
                <Border Padding="0,6" Cursor="Hand" ToolTip="Today">
                    <TextBlock Text="&#xE81C;" FontFamily="Segoe Fluent Icons"
                               FontSize="16" Foreground="#808090"
                               HorizontalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Float Panel (overlay, shown on hover) -->
        <Border x:Name="FloatPanel"
                Visibility="Collapsed"
                HorizontalAlignment="Left"
                Margin="40,0,0,0"
                MinWidth="180"
                Background="#F0202028"
                BorderBrush="#500078D4"
                BorderThickness="1"
                CornerRadius="0,4,4,0"
                Panel.ZIndex="500"
                AllowDrop="True"
                MouseEnter="FloatPanel_MouseEnter"
                MouseLeave="FloatPanel_MouseLeave"
                DragOver="FloatPanel_DragOver"
                Drop="FloatPanel_Drop"
                DragLeave="FloatPanel_DragLeaveEvent">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="3" Opacity="0.5" Direction="0"/>
            </Border.Effect>
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="4,8,4,8">
                    <!-- ==================== Pinned Section ==================== -->
                    <TextBlock Text="PINNED" FontSize="15" FontWeight="SemiBold"
                               Foreground="#888890" Margin="8,0,0,4"/>
                    <Border x:Name="PinnedDropZone" MinHeight="24"
                            Background="Transparent">
                        <StackPanel>
                            <ListBox x:Name="PinnedList" ItemsSource="{Binding PinnedItems}"
                                     Background="Transparent" BorderThickness="0"
                                     HorizontalContentAlignment="Stretch"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter HorizontalAlignment="Stretch"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="6,4" CornerRadius="3" Cursor="Hand"
                                                Background="Transparent"
                                                ToolTip="{Binding FullPath}"
                                                MouseLeftButtonUp="Pinned_Click"
                                                MouseEnter="Item_MouseEnter"
                                                MouseLeave="Item_MouseLeave"
                                                PreviewMouseLeftButtonDown="Item_PreviewMouseDown"
                                                PreviewMouseMove="Item_PreviewMouseMove"
                                                Tag="Pinned">
                                            <Border.ContextMenu>
                                                <ContextMenu Opened="PinnedContextMenu_Opened"
                                                             Closed="PinnedContextMenu_Closed">
                                                    <MenuItem Header="名前の変更" Click="PinnedRename_Click"/>
                                                    <MenuItem Header="削除" Click="PinnedDelete_Click"/>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" IsHitTestVisible="False">
                                                    <Image Source="{Binding Icon}" Width="14" Height="14"
                                                           Margin="0,0,6,0" VerticalAlignment="Center"
                                                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                                    <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="160">
                                                        <Run Text="{Binding Name, Mode=OneWay}" FontSize="13" Foreground="#D0D0D4"/>
                                                        <Run Text="{Binding ParentPath, Mode=OneWay}" FontSize="12" Foreground="#808088"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="&#xE711;" FontFamily="Segoe Fluent Icons"
                                                           FontSize="10" Foreground="#909098"
                                                           VerticalAlignment="Center"
                                                           Cursor="Hand"
                                                           MouseLeftButtonUp="PinnedClose_Click"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock x:Name="PinnedEmpty" Text="ブックマークなし" FontSize="11"
                                       Foreground="#505058" Margin="8,2,0,0"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <!-- Divider -->
                    <Border Height="1" Background="#30AAAACC" Margin="4,8,4,4"/>

                    <!-- ==================== Today Section ==================== -->
                    <TextBlock Text="TODAY" FontSize="15" FontWeight="SemiBold"
                               Foreground="#888890" Margin="8,0,0,4"/>
                    <Border x:Name="TodayDropZone" MinHeight="24"
                            Background="Transparent">
                        <StackPanel>
                            <ListBox x:Name="TodayList" ItemsSource="{Binding TodayItems}"
                                     Background="Transparent" BorderThickness="0"
                                     HorizontalContentAlignment="Stretch"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter HorizontalAlignment="Stretch"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="6,3" CornerRadius="3" Cursor="Hand"
                                                Background="Transparent"
                                                ToolTip="{Binding FullPath}"
                                                MouseLeftButtonUp="Today_Click"
                                                MouseEnter="Item_MouseEnter"
                                                MouseLeave="Item_MouseLeave"
                                                PreviewMouseLeftButtonDown="Item_PreviewMouseDown"
                                                PreviewMouseMove="Item_PreviewMouseMove"
                                                Tag="Today">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" IsHitTestVisible="False">
                                                    <Image Source="{Binding Icon}" Width="14" Height="14"
                                                           Margin="0,0,6,0" VerticalAlignment="Center"
                                                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                                    <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="160">
                                                        <Run Text="{Binding Name, Mode=OneWay}" FontSize="13" Foreground="#D0D0D4"/>
                                                        <Run Text="{Binding ParentPath, Mode=OneWay}" FontSize="12" Foreground="#808088"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="&#xE711;" FontFamily="Segoe Fluent Icons"
                                                           FontSize="10" Foreground="#909098"
                                                           VerticalAlignment="Center"
                                                           Cursor="Hand"
                                                           MouseLeftButtonUp="TodayClose_Click"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock x:Name="TodayEmpty" Text="履歴なし" FontSize="11"
                                       Foreground="#505058" Margin="8,2,0,0"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
