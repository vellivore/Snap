<Window x:Class="Snap.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Snap.Views"
        xmlns:local="clr-namespace:Snap"
        xmlns:conv="clr-namespace:Snap.Converters"
        Title="Snap" Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp">

    <Border Background="#BF181820" CornerRadius="8" BorderBrush="#50FFFFFF" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0" Background="#A01A1A22" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="Snap" Foreground="#D4D4D4" FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Window Controls -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                    <Button Content="&#x2500;" Click="MinimizeButton_Click"
                            Width="40" Height="28"
                            Background="Transparent" Foreground="#808080"
                            BorderThickness="0" FontSize="12" Cursor="Hand"/>
                    <Button x:Name="MaxRestoreButton" Content="&#x2610;" Click="MaximizeButton_Click"
                            Width="40" Height="28"
                            Background="Transparent" Foreground="#808080"
                            BorderThickness="0" FontSize="12" Cursor="Hand"/>
                    <Button Content="&#x2715;" Click="CloseButton_Click"
                            Width="40" Height="28"
                            Background="Transparent" Foreground="#808080"
                            BorderThickness="0" FontSize="12" Cursor="Hand"/>
                </StackPanel>
            </Grid>

            <!-- Main Content -->
            <Grid Grid.Row="1" ClipToBounds="False">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition x:Name="TreeColumn" Width="220" MinWidth="100"/>
                    <ColumnDefinition Width="2"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Sidebar (spans tree column so float panel is not clipped) -->
                <views:SidebarControl Grid.Column="0" Grid.ColumnSpan="2"
                                       DataContext="{Binding Sidebar}"
                                       Panel.ZIndex="500"
                                       HorizontalAlignment="Left"/>

                <!-- Folder Tree -->
                <views:FolderTreeControl Grid.Column="1"
                                          DataContext="{Binding FolderTree}"/>

                <!-- Splitter between tree and panes -->
                <GridSplitter Grid.Column="2"
                              HorizontalAlignment="Stretch"
                              Background="#30AAAACC"
                              ResizeBehavior="PreviousAndNext"/>

                <!-- Right: 4-Pane Area -->
                <Grid Grid.Column="3">
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="TopPaneRow" Height="*" MinHeight="150"/>
                        <RowDefinition Height="2"/>
                        <RowDefinition x:Name="BottomPaneRow" Height="*" MinHeight="150"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="LeftPaneColumn" Width="*" MinWidth="200"/>
                        <ColumnDefinition Width="2"/>
                        <ColumnDefinition x:Name="RightPaneColumn" Width="*" MinWidth="200"/>
                    </Grid.ColumnDefinitions>

                    <!-- Top-Left Pane -->
                    <views:TabPaneControl Grid.Row="0" Grid.Column="0"
                                          DataContext="{Binding TopLeftPane}"
                                          PreviewMouseDown="Pane_PreviewMouseDown"/>

                    <!-- Vertical Splitter (top row) -->
                    <GridSplitter Grid.Row="0" Grid.Column="1"
                                  HorizontalAlignment="Stretch"
                                  Background="#30AAAACC"
                                  ResizeBehavior="PreviousAndNext"/>

                    <!-- Top-Right Pane -->
                    <views:TabPaneControl Grid.Row="0" Grid.Column="2"
                                          DataContext="{Binding TopRightPane}"
                                          PreviewMouseDown="Pane_PreviewMouseDown"/>

                    <!-- Horizontal Splitter -->
                    <GridSplitter Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  Background="#30AAAACC"
                                  ResizeDirection="Rows"
                                  ResizeBehavior="PreviousAndNext"/>

                    <!-- Bottom-Left Pane -->
                    <views:TabPaneControl Grid.Row="2" Grid.Column="0"
                                          DataContext="{Binding BottomLeftPane}"
                                          PreviewMouseDown="Pane_PreviewMouseDown"/>

                    <!-- Vertical Splitter (bottom row) -->
                    <GridSplitter Grid.Row="2" Grid.Column="1"
                                  HorizontalAlignment="Stretch"
                                  Background="#30AAAACC"
                                  ResizeBehavior="PreviousAndNext"/>

                    <!-- Bottom-Right Pane -->
                    <views:TabPaneControl Grid.Row="2" Grid.Column="2"
                                          DataContext="{Binding BottomRightPane}"
                                          PreviewMouseDown="Pane_PreviewMouseDown"/>
                </Grid>
            </Grid>

            <!-- Common Status Bar -->
            <Border Grid.Row="2" Background="#A0181820" BorderBrush="#30AAAACC" BorderThickness="0,1,0,0">
                <DockPanel Margin="12,3">
                    <TextBlock x:Name="StatusBarText"
                               DockPanel.Dock="Left"
                               FontSize="11" Foreground="#808080"
                               VerticalAlignment="Center"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="CpuText" FontSize="11" Foreground="#607080" Margin="0,0,16,0"/>
                        <TextBlock x:Name="MemText" FontSize="11" Foreground="#607080" Margin="0,0,16,0"/>
                        <TextBlock x:Name="BatteryText" FontSize="11" Foreground="#607080" Margin="0,0,16,0"/>
                        <TextBlock x:Name="ClockText" FontSize="11" Foreground="#808080"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ==================== Command Palette (floating overlay) ==================== -->
            <!-- Shadow layer (separate so text stays hardware-rendered) -->
            <Border x:Name="CommandPaletteBorder"
                    Grid.Row="0" Grid.RowSpan="3"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,48,0,0"
                    Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}, Converter={x:Static local:HalfWidthConverter.Instance}}"
                    MaxWidth="700" MinWidth="350"
                    Panel.ZIndex="1000">
                <!-- Shadow-only border -->
                <Border Background="#E8202028"
                        BorderBrush="#500078D4"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="24" ShadowDepth="8" Opacity="0.6"/>
                    </Border.Effect>
                </Border>
            </Border>
            <!-- Content layer (no Effect, crisp text) -->
            <Border Grid.Row="0" Grid.RowSpan="3"
                    Visibility="{Binding Visibility, ElementName=CommandPaletteBorder}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,48,0,0"
                    Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}, Converter={x:Static local:HalfWidthConverter.Instance}}"
                    MaxWidth="700" MinWidth="350"
                    Background="#E8202028"
                    BorderBrush="#500078D4"
                    BorderThickness="1"
                    CornerRadius="8"
                    Panel.ZIndex="1001">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Search input -->
                    <Grid Grid.Row="0" Margin="8,8,8,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="&#xE721;"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="16" Foreground="#808090"
                                   VerticalAlignment="Center"
                                   Margin="4,0,8,0"/>
                        <TextBox x:Name="CommandPaletteInput"
                                 Grid.Column="1"
                                 FontSize="16"
                                 Background="Transparent"
                                 Foreground="#E0E0E4"
                                 CaretBrush="#E0E0E4"
                                 BorderThickness="0"
                                 Padding="4,6"
                                 Text="{Binding CommandPalette.QueryText, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewKeyDown="CommandPaletteInput_PreviewKeyDown"/>
                        <!-- Placeholder -->
                        <TextBlock Grid.Column="1"
                                   Text="コマンドを入力..."
                                   FontSize="16" Foreground="#505058"
                                   IsHitTestVisible="False"
                                   Padding="4,6"
                                   Visibility="{Binding CommandPalette.QueryText, Converter={x:Static local:EmptyToVisibleConverter.Instance}}"/>
                    </Grid>

                    <!-- Search status -->
                    <TextBlock Grid.Row="1" Text="{Binding CommandPalette.SearchStatusText}"
                               FontSize="11" Foreground="#606068" Margin="12,2,12,0"
                               Visibility="{Binding CommandPalette.SearchStatusText, Converter={x:Static local:NonEmptyToVisibleConverter.Instance}}"/>

                    <!-- Results list -->
                    <ListBox x:Name="CommandPaletteResults"
                             Grid.Row="2"
                             MaxHeight="340"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemsSource="{Binding CommandPalette.Results}"
                             SelectedItem="{Binding CommandPalette.SelectedItem, Mode=TwoWay}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Margin="4,0,4,4"
                             PreviewMouseLeftButtonUp="CommandPaletteResults_PreviewMouseLeftButtonUp">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Foreground" Value="#D0D0D4"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="Transparent"
                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#28FFFFFF"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#300078D4"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Left"
                                               Text="{Binding Icon}"
                                               FontFamily="Segoe Fluent Icons"
                                               FontSize="14" Foreground="#808090"
                                               VerticalAlignment="Center"
                                               Width="24"/>
                                    <StackPanel>
                                        <ContentPresenter Content="{Binding DisplaySegments,
                                                           Converter={x:Static conv:HighlightConverter.Instance}}"
                                                           TextBlock.FontFamily="Segoe UI Variable, Segoe UI"
                                                           TextBlock.FontSize="14"/>
                                        <ContentPresenter Content="{Binding SecondarySegments,
                                                           Converter={x:Static conv:SecondaryHighlightConverter.Instance}}"
                                                           TextBlock.FontFamily="Segoe UI Variable, Segoe UI"
                                                           TextBlock.FontSize="12"
                                                           Visibility="{Binding SecondaryText, Converter={x:Static local:NonEmptyToVisibleConverter.Instance}}"/>
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- ==================== Floating Terminal (embedded pwsh) ==================== -->
            <Border x:Name="FloatingTerminalBorder"
                    Grid.Row="0" Grid.RowSpan="3"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="800"
                    Height="450"
                    Background="#F0101018"
                    BorderBrush="#500078D4"
                    BorderThickness="1"
                    CornerRadius="6"
                    Panel.ZIndex="999">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="4" Opacity="0.5"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Terminal title bar -->
                    <Border Grid.Row="0" Background="#20FFFFFF" CornerRadius="6,6,0,0" Padding="10,4">
                        <DockPanel>
                            <TextBlock Text="Terminal (pwsh)"
                                       Foreground="#909098" FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right" Content="&#x2715;"
                                    HorizontalAlignment="Right"
                                    Background="Transparent" Foreground="#707078"
                                    BorderThickness="0" FontSize="11" Cursor="Hand"
                                    Padding="6,2"
                                    Click="TerminalClose_Click"/>
                        </DockPanel>
                    </Border>

                    <!-- Console host panel -->
                    <Border Grid.Row="1"
                            Background="#0C0C14" ClipToBounds="True"
                            CornerRadius="0,0,6,6">
                        <views:TerminalHostControl x:Name="TerminalHost"
                                                    SizeChanged="TerminalHost_SizeChanged"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
