<UserControl x:Class="Snap.Views.FilePaneControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Snap.ViewModels"
             Focusable="True"
             PreviewKeyDown="UserControl_KeyDown">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Dark GridViewColumnHeader with ControlTemplate override -->
        <Style x:Key="DarkColumnHeader" TargetType="GridViewColumnHeader">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Grid>
                            <Border x:Name="HeaderBorder"
                                    Background="#A01A1A22"
                                    BorderBrush="#383840"
                                    BorderThickness="0,0,1,1"
                                    Padding="6,1">
                                <ContentPresenter HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  SnapsToDevicePixels="True"/>
                            </Border>
                            <Thumb x:Name="PART_HeaderGripper"
                                   HorizontalAlignment="Right"
                                   Width="4"
                                   Margin="0"
                                   Background="Transparent"
                                   Cursor="SizeWE">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border Background="Transparent" Width="4"/>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="#32323A"/>
                            </Trigger>
                            <Trigger Property="Role" Value="Padding">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="#1A1A22"/>
                                <Setter TargetName="HeaderBorder" Property="BorderThickness" Value="0,0,0,1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent"
          AllowDrop="True"
          PreviewDragEnter="FileList_DragEnter"
          PreviewDragOver="FileList_DragOver"
          PreviewDrop="FileList_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Address Bar -->
        <Border Grid.Row="0" Margin="4,1,4,1" Background="#A024242C" BorderBrush="#383840"
                BorderThickness="1" CornerRadius="0"
                MouseLeftButtonDown="AddressBarBorder_Click">
            <!-- Breadcrumb mode (default) -->
            <Grid>
                <ItemsControl x:Name="BreadcrumbBar"
                              Visibility="Visible">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" Margin="2,0"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <!-- Edit mode (hidden by default) -->
                <TextBox x:Name="AddressTextBox"
                         Text="{Binding CurrentPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="AddressBar_KeyDown"
                         LostFocus="AddressBar_LostFocus"
                         Visibility="Collapsed"
                         Background="#A024242C"
                         BorderThickness="0"
                         Padding="4,1"
                         FontSize="11"
                         VerticalContentAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Search Bar removed: search is now in Command Palette (Ctrl+Space / Ctrl+F) -->

        <!-- Separator -->
        <Border Grid.Row="2" Background="#30AAAACC"/>

        <!-- File List -->
        <ListView Grid.Row="3"
                  x:Name="FileListView"
                  ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                  MouseDoubleClick="ListView_MouseDoubleClick"
                  PreviewMouseLeftButtonDown="FileList_PreviewMouseLeftButtonDown"
                  PreviewMouseMove="FileList_PreviewMouseMove"
                  AllowDrop="True"
                  PreviewMouseRightButtonDown="FileListView_PreviewMouseRightButtonDown"
                  PreviewMouseRightButtonUp="FileListView_PreviewMouseRightButtonUp"
                  PreviewDragEnter="FileList_DragEnter"
                  PreviewDragOver="FileList_DragOver"
                  PreviewDrop="FileList_Drop"
                  Background="Transparent"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  ScrollViewer.IsDeferredScrollingEnabled="False"
                  Margin="4,0,4,0"
                  FontSize="13">
            <!-- Context menu is handled natively via Shell IContextMenu (see code-behind) -->
            <ListView.View>
                <GridView ColumnHeaderContainerStyle="{StaticResource DarkColumnHeader}">
                    <GridViewColumn Header="名前 ^" Width="280">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{Binding Icon}" Width="16" Height="16"
                                           Margin="0,0,6,0" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="更新日時" Width="140"
                                    DisplayMemberBinding="{Binding DisplayDate}"/>
                    <GridViewColumn Header="サイズ" Width="90">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplaySize}" TextAlignment="Right"
                                           HorizontalAlignment="Right"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="種類" Width="120"
                                    DisplayMemberBinding="{Binding Type}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Loading Indicator -->
        <ProgressBar Grid.Row="3" IsIndeterminate="True" Height="4"
                     VerticalAlignment="Top" Margin="4,0,4,0"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

    </Grid>
</UserControl>
